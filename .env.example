# ── Neon Postgres (Airbyte destination + staging)
# Get connection string from neon.tech after creating a project
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ── Ollama (via ngrok tunnel from Mac)
# Set to your static ngrok domain after running: ngrok http 11434 --url https://YOUR_DOMAIN.ngrok-free.app
OLLAMA_BASE_URL=https://your-static-domain.ngrok-free.app
# Model to use for extraction (qwen2.5:14b recommended)
OLLAMA_MODEL=qwen2.5:14b
# Optional: basic auth for ngrok tunnel in "user:password" format. Leave blank if no auth.
OLLAMA_NGROK_AUTH=

# ── Memgraph Cloud
# Get from your Memgraph Cloud dashboard
MEMGRAPH_HOST=your-instance.memgraph.cloud
MEMGRAPH_PORT=7687
MEMGRAPH_USER=memgraph
MEMGRAPH_PASSWORD=your_password

# ── Jira (same config as v1/v2)
# Set to "true" to enable Jira push, "false" to skip
JIRA_ENABLED=true
JIRA_DOMAIN=shubhamgaur1.atlassian.net
JIRA_EMAIL=shubham.gaur@onixnet.com
# Generate at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=SCRUM
JIRA_BOARD_ID=1
JIRA_ISSUE_TYPE=Task

# ── Airbyte webhook verification
# Set a random secret and configure the same value in Airbyte connection settings
AIRBYTE_WEBHOOK_SECRET=

# ── Service
PORT=8000
LOG_LEVEL=INFO
