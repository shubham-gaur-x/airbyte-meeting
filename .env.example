# ─────────────────────────────────────────────────────────────────────────────
# meeting-memory-graph — environment variables
#
# SETUP STEPS:
#   1. Copy this file to .env:        cp .env.example .env
#   2. Fill in your credentials below
#   3. make google-auth               # auto-generates GOOGLE_REFRESH_TOKEN
#   4. make slack-auth                # auto-generates SLACK_REFRESH_TOKEN
#   5. make graph-setup               # creates Memgraph indexes
#   6. make airbyte-setup             # configures Airbyte Cloud (needs AIRBYTE_API_KEY)
#   7. make deploy-render             # deploy to Render.com
# ─────────────────────────────────────────────────────────────────────────────

# ── Neon Postgres (Airbyte destination + staging)
# Get connection string from neon.tech after creating a project
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ── Groq (cloud LLM — preferred, no GPU or tunneling needed)
# Get free API key at https://console.groq.com → API Keys
GROQ_API_KEY=

# ── Ollama (local fallback — only used if GROQ_API_KEY is not set)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_NGROK_AUTH=

# ── Memgraph Cloud
# Get host from https://cloud.memgraph.com → your project → Connection
MEMGRAPH_HOST=your-instance.memgraph.cloud
MEMGRAPH_PORT=7687
MEMGRAPH_USER=memgraph
MEMGRAPH_PASSWORD=your_password

# ── Jira
# Generate API token at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_ENABLED=true
JIRA_DOMAIN=your-domain.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=SCRUM
JIRA_BOARD_ID=1
JIRA_ISSUE_TYPE=Task

# ── Airbyte Cloud API (for scripts/setup_airbyte.py)
# API key: Airbyte Cloud → Settings → API keys → Create key (requires paid plan)
AIRBYTE_API_KEY=
# Workspace ID: from the URL cloud.airbyte.com/workspaces/<THIS-ID>/...
AIRBYTE_WORKSPACE_ID=
# Public URL of the deployed transform service (set after Render deploy)
WEBHOOK_BASE_URL=

# ── Google OAuth2 (Gmail + Google Calendar Airbyte sources)
# One-time setup:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create Credentials → OAuth 2.0 Client ID → Desktop App
#   3. Copy Client ID and Client Secret here
#   4. Run: make google-auth   (auto-fills GOOGLE_REFRESH_TOKEN)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Slack OAuth2
# One-time setup:
#   1. Go to https://api.slack.com/apps → Create New App → From scratch
#   2. OAuth & Permissions → add bot scopes (see scripts/get_slack_token.py)
#   3. Basic Information → copy Client ID and Client Secret here
#   4. Run: make slack-auth   (auto-fills SLACK_REFRESH_TOKEN)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REFRESH_TOKEN=

# ── Airbyte webhook verification
AIRBYTE_WEBHOOK_SECRET=

# ── Service
PORT=8000
LOG_LEVEL=INFO
